{
  "name": "pk-sweeper",
  "version": "0.1.2",
  "private": false,
  "license": "MIT",
  "bin": {
    "pk-sweeper": "dist/pksweeper.js",
    "pksweeper": "dist/pksweeper.js"
  },
  "files": [
    "dist",
    "prompts",
    "schema",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "scripts": {
    "build": "tsgo -p tsconfig.json",
    "prepare": "npm run build",
    "plan": "node dist/pksweeper.js plan",
    "review": "node dist/pksweeper.js review",
    "quick": "node dist/pksweeper.js quick",
    "apply-artifacts": "node dist/pksweeper.js apply-artifacts",
    "apply-decisions": "node dist/pksweeper.js apply-decisions",
    "audit": "node dist/pksweeper.js audit",
    "reconcile": "node dist/pksweeper.js reconcile",
    "dashboard": "node dist/pksweeper.js dashboard",
    "status": "node dist/pksweeper.js status",
    "test": "npm run build && node --test test/*.test.mjs",
    "test:unit": "node --test test/*.test.mjs",
    "lint": "oxlint src --tsconfig tsconfig.json",
    "format": "oxfmt --write src test package.json tsconfig.json .oxfmtrc.json schema .github/workflows",
    "format:check": "oxfmt --check src test package.json tsconfig.json .oxfmtrc.json schema .github/workflows",
    "oxformat": "npm run format",
    "oxformat:check": "npm run format:check",
    "check": "npm run build && npm run lint && npm run test:unit && npm run format:check"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@typescript/native-preview": "7.0.0-dev.20260423.1",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0"
  },
  "engines": {
    "node": ">=24"
  }
}
